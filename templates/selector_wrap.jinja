# meson-jll: name={{ name }} version={{ version }}
# Meson requires a source for every [wrap-file], even an overlay-only one,
# so this points at a shared empty archive instead of a real download (see
# generate::EMPTY_TAR_FILENAME). The actual content comes entirely from
# patch_directory below.
[wrap-file]
directory = {{ name }}
source_filename = {{ empty_tar_filename }}
patch_directory = {{ name }}

[provide]
# Makes a dependency('{{ name }}_jll') call in a consuming project resolve
# to this subproject automatically, with no fallback wiring. The name is
# `_jll`-suffixed rather than bare so it never collides with a same-named
# system library that Meson would otherwise satisfy the call from first.
dependency_names = {{ name }}_jll
